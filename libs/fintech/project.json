{
  "name": "fintech",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/fintech/src",
  "prefix": "nxp",
  "projectType": "library",
  "tags": ["scope:fintech"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/fintech/ng-package.json",
        "tsConfig": "libs/fintech/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/fintech/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
